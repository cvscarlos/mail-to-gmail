{
  "name": "zoho-to-gmail",
  "version": "1.0.0",
  "description": "Sync Zoho Mail (including Zoho Free) to Gmail without IMAP on the source side",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "reset": "tsx src/index.ts reset-checkpoints",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "setup:zoho": "tsx tools/zoho-setup.ts"
  },
  "dependencies": {
    "axios": "1.15.0",
    "chalk": "^5.6.2",
    "commander": "14.0.3",
    "dotenv": "17.4.2",
    "imapflow": "1.3.1",
    "inquirer": "^13.4.1",
    "libsql": "^0.5.29",
    "p-retry": "8.0.0",
    "proper-lockfile": "4.1.2",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/inquirer": "^9.0.9",
    "@types/node": "25.6.0",
    "@types/proper-lockfile": "4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
