{
  "name": "mail-bridge",
  "version": "1.0.0",
  "description": "Production-quality email sync tool (Zoho -> Gmail)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "setup:zoho": "tsx tools/zoho-setup.ts"
  },
  "dependencies": {
    "axios": "1.15.0",
    "better-sqlite3": "12.9.0",
    "commander": "14.0.3",
    "dotenv": "17.4.2",
    "imapflow": "1.3.1",
    "inquirer": "^13.4.1",
    "p-retry": "8.0.0",
    "proper-lockfile": "4.1.2",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/inquirer": "^9.0.9",
    "@types/node": "25.6.0",
    "@types/proper-lockfile": "4.1.4",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
