{
  "name": "mail-to-gmail",
  "version": "2.0.0",
  "description": "Self-hosted Gmailify replacement: sync Zoho / Yahoo / Outlook mail into one or more Gmail accounts",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --max-old-space-size=192 dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "setup:zoho": "tsx tools/zoho-setup.ts",
    "setup:imap-source": "tsx tools/setup-imap-source.ts",
    "setup:gmail-destination": "tsx tools/setup-gmail-destination.ts"
  },
  "dependencies": {
    "axios": "1.15.0",
    "chalk": "^5.6.2",
    "commander": "14.0.3",
    "dotenv": "17.4.2",
    "imapflow": "1.3.1",
    "inquirer": "^13.4.1",
    "libsql": "^0.5.29",
    "lru-cache": "^11.3.5",
    "p-retry": "8.0.0",
    "proper-lockfile": "4.1.2",
    "winston": "3.19.0",
    "yaml": "^2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/inquirer": "^9.0.9",
    "@types/node": "25.6.0",
    "@types/proper-lockfile": "4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
