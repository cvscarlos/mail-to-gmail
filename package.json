{
  "name": "mail-to-gmail",
  "version": "2.2.0",
  "description": "Self-hosted Gmailify replacement: sync Zoho / Yahoo / Outlook mail into one or more Gmail accounts",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:ts": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "precommit": "lint-staged && tsc --noEmit",
    "setup:zoho": "tsx tools/zoho-setup.ts",
    "setup:imap-source": "tsx tools/setup-imap-source.ts",
    "setup:gmail-destination": "tsx tools/setup-gmail-destination.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "imapflow": "^1.3.2",
    "libsql": "^0.5.29",
    "lru-cache": "^11.3.5",
    "p-retry": "^8.0.0",
    "proper-lockfile": "^4.1.2",
    "winston": "^3.19.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@types/node": "^24.12.2",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
