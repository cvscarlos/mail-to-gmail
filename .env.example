# App Settings
APP_LOG_LEVEL="info"
STATE_DB_PATH="./mail-bridge.db"

# Zoho Source Settings
# DC options: com, eu, in, com.au, com.cn
ZOHO_DC="com"
ZOHO_CLIENT_ID="your_client_id"
ZOHO_CLIENT_SECRET="your_client_secret"
ZOHO_REFRESH_TOKEN="your_refresh_token"
# Optional: will auto-discover if omitted
ZOHO_ACCOUNT_ID=""
ZOHO_FOLDER_NAMES="Inbox"

# Gmail Destination Settings
GMAIL_EMAIL="your_email@gmail.com"
# Use an App Password, NOT your main password
GMAIL_APP_PASSWORD="your_app_password"
GMAIL_TARGET_MAILBOX="INBOX"

# Sync Engine Settings
SYNC_LOOKBACK_DAYS="1"
MAX_MESSAGES_PER_RUN="500"
CONCURRENCY="5"

# Optional: Set to true for dry-run mode (or use --dry-run flag)
DRY_RUN="false"
# Optional: Path to a JSON filter config file
FILTER_CONFIG_PATH="./filter.json"
