# mail-to-gmail secrets.
#
# The config.yaml references these via `credentialsPrefix: <PREFIX>`.
# For a source/destination with credentialsPrefix: FOO, we read every FOO_* key here.
# Copy this file to .env and fill in your own values.
#
# Format is plain KEY=VALUE so this file works with Docker `env_file`, Fly.io
# secrets, CI env injection, and dotenv parsers.
#
# For bash/zsh: `source .env` alone only sets shell-local vars — child processes
# (Node) won't see them. Either (a) prefix each line with `export` and source it,
# or (b) use `set -a && source .env && set +a` which auto-exports everything.

# App-level settings (optional — defaults shown).
APP_LOG_LEVEL=info
STATE_DB_PATH=./mail-to-gmail.db
CONFIG_PATH=./config.yaml
DRY_RUN=false

# -----------------------------------------------------------------------------
# Zoho Mail (HTTP API, Zoho Free compatible).
# Create a Self Client at https://api-console.zoho.com/ and run `npm run setup:zoho`.
# -----------------------------------------------------------------------------
ZOHO_MAIN_DC=com
ZOHO_MAIN_CLIENT_ID=your_client_id
ZOHO_MAIN_CLIENT_SECRET=your_client_secret
ZOHO_MAIN_REFRESH_TOKEN=your_refresh_token
# ZOHO_MAIN_ACCOUNT_ID=optional_auto_discovered

# -----------------------------------------------------------------------------
# Yahoo (IMAP + app password).
# Generate at https://login.yahoo.com/account/security → App passwords.
# -----------------------------------------------------------------------------
YAHOO_PERSONAL_EMAIL=you@yahoo.com
YAHOO_PERSONAL_APP_PASSWORD=16_char_app_password

YAHOO_WORK_EMAIL=you@yahoo.com
YAHOO_WORK_APP_PASSWORD=16_char_app_password

# -----------------------------------------------------------------------------
# Outlook.com / Hotmail (IMAP + app password).
# Generate at https://account.live.com/proofs/AppPassword (2FA required).
# -----------------------------------------------------------------------------
OUTLOOK_PERSONAL_EMAIL=you@outlook.com
OUTLOOK_PERSONAL_APP_PASSWORD=16_char_app_password

OUTLOOK_WORK_EMAIL=you@hotmail.com
OUTLOOK_WORK_APP_PASSWORD=16_char_app_password

# -----------------------------------------------------------------------------
# Gmail destinations (IMAP APPEND + app password).
# Generate at https://myaccount.google.com/apppasswords (2FA required).
# -----------------------------------------------------------------------------
GMAIL_1_EMAIL=primary@gmail.com
GMAIL_1_APP_PASSWORD=16_char_app_password

GMAIL_2_EMAIL=secondary@gmail.com
GMAIL_2_APP_PASSWORD=16_char_app_password
